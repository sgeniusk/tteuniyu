# apps/web 로컬 개발 환경변수 템플릿
#
# 사용법:
#   cp .env.local.example .env.local
#   # 아래 값들을 Supabase Dashboard → Project Settings → API 에서 복사
#   pnpm dev
#
# 비협상 (CLAUDE.md rule 11) — SUPABASE_SERVICE_ROLE_KEY는 server-only.
# NEXT_PUBLIC_ prefix 절대 붙이지 말 것 (client bundle 노출 = security incident).

# ─── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://qzouxgfsbiiyfxnevmvy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role secret 여기 붙여넣기>

# ─── 선택 — base URL (server component fetch에서 사용) ────
# 로컬은 default localhost:3000, Vercel은 자동으로 VERCEL_URL 잡힘
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
