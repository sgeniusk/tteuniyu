# 뜬이유 워커 환경변수 — 실 운영 값은 .env (gitignore)에 둘 것.
# CLAUDE.md rule 11 — service_role key는 워커·Next.js server route만. client 노출 X.

# ─ Supabase (PR #23~#24 진입 시 필수, PR #22 dry-run에서는 미사용) ─
SUPABASE_URL=https://example.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─ LLM (ADR-014, PR #24 진입 시 필수) ─
GEMINI_API_KEY=

# ─ 비용 모니터링 (ADR-014 — $50/월 cap) ─
SLACK_WEBHOOK_URL=
MONTHLY_COST_CAP_USD=50

# ─ 로깅 ─
LOG_LEVEL=INFO
LOG_FORMAT=json   # plain|json — GHA·운영은 json, 로컬 디버그는 plain

# ─ 동시성 제어 (RSS fetch) ─
MAX_CONCURRENT_FETCH=6
